{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RustyDownloader",
  "version": "0.1.0",
  "identifier": "com.huy.rustydownloader",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "RustyDownloader",
        "width": 1100,
        "height": 720,
        "minWidth": 800,
        "minHeight": 500,
        "center": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
